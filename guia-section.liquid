{% comment %}
  Sección Guía Científica - Popup funcional garantizado
{% endcomment %}

<section id="section-{{ section.id }}" data-section-id="{{ section.id }}" style="background: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    
    <div style="border: 2px dashed {{ section.settings.accent_color }}; border-radius: 16px; padding: 25px; max-width: 600px; margin: 0 auto; background: {{ section.settings.box_bg_color }};">
      
      <div style="display: flex; align-items: flex-start; gap: 15px; margin-bottom: 20px;">
        <span style="font-size: 2.5rem; flex-shrink: 0;">{{ section.settings.icon }}</span>
        <div>
          <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 5px; color: {{ section.settings.text_color }}; line-height: 1.3;">{{ section.settings.title }}</h3>
          <p style="font-size: 0.95rem; color: {{ section.settings.subtitle_color }}; line-height: 1.5; margin: 0;">{{ section.settings.subtitle }}</p>
        </div>
      </div>
      
      <button type="button" onclick="if(typeof openGuiaPopup === 'function') openGuiaPopup(); else alert('Popup no cargado. Recarga la página.');" style="width: 100%; padding: 14px 24px; background: transparent; border: 2px solid {{ section.settings.accent_color }}; border-radius: 10px; color: {{ section.settings.accent_color }}; font-weight: 600; font-size: 1rem; cursor: pointer; transition: all 0.3s;">
        {{ section.settings.button_text }}
      </button>
      
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Guía Científica",
  "tag": "section",
  "class": "section-guia",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "label": "Ícono",
      "default": "📖"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "¿Quieres saber más sobre creatina?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descarga al comprar nuestra CREATINA la guía científica gratuita"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Descargar"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo de la sección",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "box_bg_color",
      "label": "Color de fondo del cuadro",
      "default": "rgba(78, 205, 196, 0.05)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del título",
      "default": "#2d3748"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del subtítulo",
      "default": "#718096"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#4ECDC4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado Superior",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado Inferior",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 40,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Guía Científica"
    }
  ]
}
{% endschema %}
