{% comment %}
  Footer - Corregido y Responsive
{% endcomment %}

<footer class="site-footer" style="background: #1a1a1a; color: white; padding: 60px 0 30px;">
  <div class="container">
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px; margin-bottom: 40px;">
      
      <!-- Logo y descripción -->
      <div>
        <h3 style="color: #ff6b35; font-size: 1.3rem; margin-bottom: 15px; font-weight: 700;">
          {% if settings.logo != blank %}
            <img src="{{ settings.logo | img_url: 'small' }}" alt="{{ shop.name }}" style="max-height: 40px; filter: brightness(0) invert(1);">
          {% else %}
            {{ shop.name }}
          {% endif %}
        </h3>
        <p style="color: #aaa; line-height: 1.7; font-size: 0.95rem;">
          Suplementos de alta calidad para potenciar tu rendimiento.
        </p>
      </div>
      
      <!-- Enlaces -->
      <div>
        <h4 style="color: #ff6b35; font-size: 1.1rem; margin-bottom: 15px;">Enlaces</h4>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="margin-bottom: 10px;">
            <a href="/" style="color: #aaa; text-decoration: none; transition: color 0.2s;">Inicio</a>
          </li>
          <li style="margin-bottom: 10px;">
            <a href="/collections/all" style="color: #aaa; text-decoration: none; transition: color 0.2s;">Catálogo</a>
          </li>
          <li style="margin-bottom: 10px;">
            <a href="/cart" style="color: #aaa; text-decoration: none; transition: color 0.2s;">Carrito</a>
          </li>
        </ul>
      </div>
      
      <!-- Contacto -->
      <div>
        <h4 style="color: #ff6b35; font-size: 1.1rem; margin-bottom: 15px;">Contacto</h4>
        <p style="color: #aaa; line-height: 1.8; font-size: 0.95rem;">
          {% if section.settings.email != blank %}
            📧 {{ section.settings.email }}<br>
          {% endif %}
          🚚 Envío gratis a todo Chile<br>
          💰 Pago contraentrega
        </p>
      </div>
      
    </div>
    
    <div style="text-align: center; padding-top: 30px; border-top: 1px solid #333; color: #666; font-size: 0.9rem;">
      © {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.
    </div>
    
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "email",
      "label": "Email de contacto",
      "default": "homadropi@gmail.com"
    }
  ]
}
{% endschema %}
