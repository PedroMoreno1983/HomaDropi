          <span class="spec-label">Contenido Neto</span>
        </div>
      </div>
      
      <div class="spec-card">
        <div class="spec-icon">🥤</div>
        <div class="spec-info">
          <span class="spec-value-large">60</span>
          <span class="spec-label">Servicios</span>
        </div>
      </div>
      
      <div class="spec-card">
        <div class="spec-icon">💊</div>
        <div class="spec-info">
          <span class="spec-value-large">5g</span>
          <span class="spec-label">Creatina por servicio</span>
        </div>
      </div>
      
      <div class="spec-card">
        <div class="spec-icon">🔬</div>
        <div class="spec-info">
          <span class="spec-value-large">200</span>
          <span class="spec-label">Mesh (micronizada)</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRODUCT TABS -->
<section class="product-tabs-section">
  <div class="container">
    <div class="tabs-wrapper">
      <div class="tabs-header">
