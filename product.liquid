<!-- PRODUCT HERO -->
<section class="product-hero">
  <div class="container">
    <div class="product-breadcrumbs">
      <a href="/">Inicio</a>
      <span>/</span>
      <a href="/collections/all">Productos</a>
      <span>/</span>
      <span>{{ product.title }}</span>
    </div>
    
    <div class="product-main">
      <div class="product-gallery">
        <div class="gallery-main">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: 'large' }}" alt="{{ product.title }}" id="main-image" loading="eager">
          {% else %}
            <img src="{{ 'creatina-producto.png' | asset_url }}" alt="{{ product.title }}" id="main-image" loading="eager">
          {% endif %}
        </div>
        
        {% if product.images.size > 1 %}
          <div class="gallery-thumbs">
            {% for image in product.images %}
              <button class="thumb-btn {% if forloop.first %}active{% endif %}" data-image="{{ image | img_url: 'large' }}">
                <img src="{{ image | img_url: 'small' }}" alt="{{ product.title }} - Vista {{ forloop.index }}">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>
      
      <div class="product-details">
        <span class="product-brand-badge">Vidanova Suples</span>
        <h1 class="product-name">{{ product.title }}</h1>
        
        <div class="product-rating">
          <span class="stars">⭐⭐⭐⭐⭐</span>
          <span class="rating-count">4.9 (127 reseñas)</span>
        </div>
        
        <div class="product-short-desc">
          <p>Creatina Monohidratada Micronizada PRO - 300g / 60 servicios. La forma más estudiada y efectiva de creatina para potenciar tu rendimiento.</p>
        </div>
        
        <div class="product-price-wrap">
          {% if product.compare_at_price > product.price %}
            <span class="price-compare">{{ product.compare_at_price | money }}</span>
          {% endif %}
          <span class="price-sale">{{ product.price | money }}</span>
          <span class="price-tag">Oferta especial</span>
        </div>
        
        <div class="product-includes">
          <div class="include-item">
            <span class="include-icon">📚</span>
            <span><strong>Guía gratuita</strong> incluida</span>
          </div>
          <div class="include-item">
            <span class="include-icon">🚚</span>
            <span><strong>Envío gratis</strong> a todo Chile</span>
          </div>
          <div class="include-item">
            <span class="include-icon">💰</span>
            <span><strong>Contraentrega</strong> - Paga al recibir</span>
          </div>
        </div>
        
        {% form 'product', product %}
          <div class="product-variants">
            {% if product.variants.size > 1 %}
              <label for="variant-select">Selecciona tu opción:</label>
              <select name="id" id="variant-select" class="variant-select">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} - {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            {% else %}
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            {% endif %}
          </div>
          
          <div class="product-quantity">
            <label for="quantity">Cantidad:</label>
            <div class="quantity-selector">
              <button type="button" class="qty-btn qty-minus">-</button>
              <input type="number" name="quantity" id="quantity" value="1" min="1" max="10">
              <button type="button" class="qty-btn qty-plus">+</button>
            </div>
          </div>
          
          <div class="product-actions">
            <button type="submit" class="btn btn-primary btn-xlarge btn-add-cart">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 6h15l-1.5 9h-12L6 6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="9" cy="20" r="1.5" fill="currentColor"/>
                <circle cx="18" cy="20" r="1.5" fill="currentColor"/>
                <path d="M6 6L5 3H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Agregar al Carrito
            </button>
          </div>
        {% endform %}
        
        <div class="product-trust">
          <div class="trust-item">
            <span class="trust-icon">✓</span>
            <span>Producto original</span>
          </div>
          <div class="trust-item">
            <span class="trust-icon">✓</span>
            <span>Envío gratis</span>
          </div>
          <div class="trust-item">
            <span class="trust-icon">✓</span>
            <span>Contraentrega</span>
          </div>
        </div>
        
        <div class="product-guia-cta">
          <div class="guia-cta-content">
            <span class="guia-cta-icon">📖</span>
            <div class="guia-cta-text">
              <strong>¿Quieres saber más sobre creatina?</strong>
              <span>Descarga al comprar nuestra CREATINA la guía científica gratuita</span>
            </div>
          </div>
          <button class="btn btn-secondary" onclick="openGuiaPopup()">Descargar</button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRODUCT SPECS -->
