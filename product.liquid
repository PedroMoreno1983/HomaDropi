<!-- RELATED PRODUCTS -->
{% if collection.products.size > 1 %}
<section class="related-products">
  <div class="container">
    <h2 class="section-title">También te puede interesar</h2>
    <div class="products-grid">
      {% for related_product in collection.products limit: 4 %}
        {% unless related_product.id == product.id %}
          <div class="product-card">
            <a href="{{ related_product.url }}">
              <div class="product-card-image">
                <img src="{{ related_product.featured_image | img_url: 'medium' }}" alt="{{ related_product.title }}" loading="lazy">
              </div>
              <h3 class="product-card-title">{{ related_product.title }}</h3>
              <span class="product-card-price">{{ related_product.price | money }}</span>
            </a>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- FINAL CTA -->
<section class="product-final-cta">
  <div class="container">
    <div class="final-cta-wrapper">
      <h2>¿Listo para transformar tu rendimiento?</h2>
      <p>Obtén tu Creatina Vidanova PRO con envío gratis y guía completa</p>
      <div class="final-cta-price">
        <span class="fcp-price">{{ product.price | money }}</span>
        <span class="fcp-note">Envío gratis · Guía incluida · Contraentrega</span>
      </div>
      <button class="btn btn-primary btn-xlarge" onclick="document.querySelector('.product-actions button').click()">
        Comprar Ahora
      </button>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Tabs functionality
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');
  
  tabBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const tabId = this.dataset.tab;
      
      tabBtns.forEach(b => b.classList.remove('active'));
      tabPanels.forEach(p => p.classList.remove('active'));
      
      this.classList.add('active');
      document.getElementById(tabId).classList.add('active');
    });
  });
  
  // Quantity selector
  const qtyInput = document.getElementById('quantity');
  const qtyMinus = document.querySelector('.qty-minus');
  const qtyPlus = document.querySelector('.qty-plus');
  
  if (qtyMinus && qtyPlus && qtyInput) {
    qtyMinus.addEventListener('click', function() {
      let val = parseInt(qtyInput.value);
      if (val > 1) qtyInput.value = val - 1;
    });
    
    qtyPlus.addEventListener('click', function() {
      let val = parseInt(qtyInput.value);
      if (val < 10) qtyInput.value = val + 1;
    });
  }
  
  // Gallery thumbs
  const thumbBtns = document.querySelectorAll('.thumb-btn');
  const mainImage = document.getElementById('main-image');
  
  thumbBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      thumbBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      mainImage.src = this.dataset.image;
    });
  });
});
</script>
