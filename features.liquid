{% comment %}
  Características - Corregido texto que se corta
{% endcomment %}

<section class="features-section" id="section-{{ section.id }}" style="background: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="container">
    
    {% if section.settings.title != blank %}
      <h2 class="section-title" style="color: {{ section.settings.text_color }}; text-align: center; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 10px;">{{ section.settings.title }}</h2>
    {% endif %}
    
    {% if section.settings.subtitle != blank %}
      <p class="section-subtitle" style="color: {{ section.settings.subtitle_color }}; text-align: center; font-size: 1.1rem; margin-bottom: 40px;">{{ section.settings.subtitle }}</p>
    {% endif %}
    
    <div class="features-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 25px; padding: 20px 0;">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="feature-card" {{ block.shopify_attributes }} style="text-align: center; padding: 35px 25px; border-radius: 16px; background: white; border: 2px solid #f0f0f0; transition: all 0.3s ease; word-wrap: break-word;">
            
            <div class="feature-icon" style="font-size: 3rem; margin-bottom: 15px;">{{ block.settings.icon }}</div>
            
            <h3 class="feature-title" style="color: {{ section.settings.text_color }}; font-size: 1.15rem; font-weight: 700; margin-bottom: 10px; line-height: 1.3; word-break: keep-all; hyphens: none;">
              {{ block.settings.title }}
            </h3>
            
            <p class="feature-description" style="font-size: 0.95rem; color: #718096; line-height: 1.6; margin: 0;">
              {{ block.settings.description }}
            </p>
            
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
  </div>
</section>

<style>
  .feature-card:hover {
    border-color: #ff6b35;
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }
  
  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr !important;
    }
    
    .feature-card {
      padding: 30px 20px !important;
    }
    
    .feature-title {
      font-size: 1.2rem !important;
    }
  }
</style>

{% schema %}
{
  "name": "Características",
  "tag": "section",
  "class": "section-features",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "¿Por qué elegir HomaDropi?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Nos comprometemos con tu éxito ofreciendo solo lo mejor"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#2d3748"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del subtítulo",
      "default": "#718096"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado Superior",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado Inferior",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Característica",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Ícono/Emoji",
          "default": "✅"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Calidad Garantizada"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción",
          "default": "Productos 100% originales y certificados. Trabajamos solo con marcas de confianza."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Características",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "✅",
            "title": "Calidad Garantizada",
            "description": "Productos 100% originales y certificados. Trabajamos solo con marcas de confianza."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🚚",
            "title": "Envío Rápido",
            "description": "Despacho a todo Chile con seguimiento en tiempo real de tu pedido."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "💰",
            "title": "Pago Contraentrega",
            "description": "Paga solo cuando recibas el producto en la puerta de tu casa. Sin riesgos."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "📞",
            "title": "Soporte 24/7",
            "description": "Estamos aquí para ayudarte. Contacto directo por WhatsApp y email."
          }
        }
      ]
    }
  ]
}
{% endschema %}
