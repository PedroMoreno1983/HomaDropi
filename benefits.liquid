{% comment %}
  Sección Benefits - Editable desde el editor de Shopify
{% endcomment %}

<section class="benefits" id="section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="container">
    {% if section.settings.show_header %}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.title }}</h2>
        {% if section.settings.subtitle != blank %}
          <p class="section-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}
    
    <div class="benefits-grid" style="grid-template-columns: repeat({{ section.settings.columns }}, 1fr);">
      {% for block in section.blocks %}
        {% if block.type == 'benefit' %}
          <div class="benefit-card" {{ block.shopify_attributes }}>
            <div class="benefit-icon">
              {% if block.settings.icon_type == 'svg' %}
                {{ block.settings.svg_icon }}
              {% else %}
                <span style="font-size: 48px;">{{ block.settings.emoji_icon }}</span>
              {% endif %}
            </div>
            <h3 class="benefit-title">{{ block.settings.title }}</h3>
            <p class="benefit-text">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  
  #section-{{ section.id }} .section-title {
    color: {{ section.settings.title_color }};
  }
  
  #section-{{ section.id }} .section-subtitle {
    color: {{ section.settings.subtitle_color }};
  }
  
  #section-{{ section.id }} .benefit-card {
    background-color: {{ section.settings.card_bg_color }};
  }
  
  #section-{{ section.id }} .benefit-icon {
    color: {{ section.settings.icon_color }};
  }
  
  #section-{{ section.id }} .benefit-title {
    color: {{ section.settings.card_title_color }};
  }
  
  #section-{{ section.id }} .benefit-text {
    color: {{ section.settings.card_text_color }};
  }
</style>

{% schema %}
{
  "name": "Beneficios",
  "tag": "section",
  "class": "section-benefits",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Mostrar encabezado",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "¿Por qué elegir HomaDropi?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Nos comprometemos con tu éxito ofreciendo solo lo mejor"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columnas",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del Título",
      "default": "#2D3748"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del Subtítulo",
      "default": "#718096"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Color de Fondo de Tarjetas",
      "default": "#F7FAFC"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color de Íconos",
      "default": "#FF6B4A"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Color de Título de Tarjetas",
      "default": "#2D3748"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Color de Texto de Tarjetas",
      "default": "#718096"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado Superior",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado Inferior",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 80,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Tipo de Ícono",
          "options": [
            {
              "value": "emoji",
              "label": "Emoji"
            },
            {
              "value": "svg",
              "label": "SVG"
            }
          ],
          "default": "emoji"
        },
        {
          "type": "text",
          "id": "emoji_icon",
          "label": "Emoji",
          "default": "✅"
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "Código SVG del Ícono"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Calidad Garantizada"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Productos 100% originales y certificados. Trabajamos solo con marcas reconocidas."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "emoji_icon": "✅",
            "title": "Calidad Garantizada",
            "text": "Productos 100% originales y certificados. Trabajamos solo con marcas reconocidas."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji_icon": "🚚",
            "title": "Envío Gratis",
            "text": "Despacho sin costo a todo Chile. Paga solo cuando recibes tu producto."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji_icon": "📚",
            "title": "Guía Profesional",
            "text": "Recibe nuestra guía completa sobre creatina con información científica."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji_icon": "⭐",
            "title": "Satisfacción Garantizada",
            "text": "Tu satisfacción es nuestra prioridad. Estamos aquí para ayudarte."
          }
        }
      ]
    }
  ]
}
{% endschema %}
